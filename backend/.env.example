# Database Configuration (REQUIRED)
DATABASE_URL=postgresql://user:password@localhost:5432/db_name

# JWT Configuration (REQUIRED)
JWT_SECRET=your_secret_key
JWT_EXPIRES_IN=7d

# Node Environment
NODE_ENV=production

# Cloudinary Configuration (Required for file uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# PayDunya Configuration (Optional - only if using PayDunya payments)
PAYDUNYA_MASTER_KEY=your-paydunya-master-key
PAYDUNYA_PRIVATE_KEY=your-paydunya-private-key
PAYDUNYA_PUBLIC_KEY=your-paydunya-public-key
PAYDUNYA_TOKEN=your-paydunya-token

# Frontend URL (For CORS and redirects)
FRONTEND_URL=http://localhost:3000

# Backend URL (For callbacks and API references)
BACKEND_URL=http://localhost:3001

# Application Port (Optional - defaults to 3000)
PORT=3000